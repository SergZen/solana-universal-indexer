# ── Required ────────────────────────────────────────────────────────────────
RPC_URL=https://api.devnet.solana.com
PROGRAM_ID=6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P

# PostgreSQL connection string
DATABASE_URL=postgres://indexer:indexer@localhost:5432/indexer

# ── IDL source ───────────────────────────────────────────────────────────────
# "onchain" (default) or "file"
IDL_SOURCE=onchain
# Only used when IDL_SOURCE=file:
# IDL_PATH=./idl/my_program.json

# ── Indexer mode ─────────────────────────────────────────────────────────────
# "realtime" (default) or "batch"
INDEXER_MODE=realtime

# WebSocket URL (defaults to wss:// version of RPC_URL)
# WS_URL=wss://api.mainnet-beta.solana.com

# ── Batch mode options ────────────────────────────────────────────────────────
# START_SLOT=453721000
# END_SLOT=453721100
# Comma-separated explicit signatures:
# SIGNATURES=5abc...,6def...

# ── Tuning ───────────────────────────────────────────────────────────────────
BATCH_SIZE=100
POLL_INTERVAL_SECS=5
RPC_MAX_RETRIES=5

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=3000

# ── Logging ───────────────────────────────────────────────────────────────────
# RUST_LOG=info
# LOG_FORMAT=json   # or "pretty" (default)